# LiveKit Cloud — project settings page
LIVEKIT_URL=wss://voxaris-vba.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# xAI — console.x.ai → API keys
# Used for the LLM (Grok-4-fast via OpenAI-compatible endpoint).
XAI_API_KEY=

# Deepgram — console.deepgram.com → API keys
# Used for streaming STT (Nova-3 model).
DEEPGRAM_API_KEY=

# Cartesia — cartesia.ai → API keys
# Primary TTS for Andie (Sonic-3 model + cloned Andy voice).
CARTESIA_API_KEY=

# Rime — rime.ai → API keys
# Fallback TTS (mistv3 + arcana) used if Cartesia is unavailable.
RIME_API_KEY=

# Supabase — project settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Twilio — prod sub-account (NOT the PCI-mode payments sub-account)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VOICE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Twilio — payments sub-account (PCI Mode ON; separate creds)
TWILIO_PAY_ACCOUNT_SID=
TWILIO_PAY_AUTH_TOKEN=

# Stripe — Test Mode for the demo
STRIPE_SECRET_KEY=sk_test_

# Fallback live agent for transfer_to_human
LIVE_AGENT_NUMBER=+15555550100

# Logging
LOG_LEVEL=INFO
